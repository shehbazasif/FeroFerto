# Feroferto Website Environment Variables

# API Configuration
NUXT_PUBLIC_API_BASE=https://api.feroferto.com
NUXT_PUBLIC_API_VERSION=v1

# Analytics (optional)
NUXT_PUBLIC_GA_ID=

# Sentry Error Tracking (optional)
NUXT_PUBLIC_SENTRY_DSN=

# Feature Flags
NUXT_PUBLIC_ENABLE_DEMO_VIDEOS=true
NUXT_PUBLIC_ENABLE_LIVE_CHAT=true

# Image Optimization
NUXT_IMAGE_CLOUDINARY_CLOUD=your-cloud-name
